{
  "App": {
    "Version": "1.0.0.0",
    "ShutdownTimeout": 10,
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ],
        "UseHttpsRedirection": false
      },
      "MultipartLimits": {
        "MaxUploadBytes": 33554432,
        "KeepAliveTimeout": 130
      }
    },
    "HttpPolicyHeaders": {
      "ContentType": null,
      "ReferrerPolicy": null,
      "FrameOptions": null,
      "XssProtection": null,
      "Csp": null,
      "Cors": null,
      "Hsts": null,
      "Robots": null,
      "ForwardedHeaders": {
        "Headers": "All",
        "RequireHeaderSymmetry": false
      }
    },
    "ResponseCache": {
      "MaxSize": 1024,
      "MaxBodySize": 102400,
      "MaxAge": "00:20:00"
    },
    "ResponseCompression": {
      "UseGzip": true,
      "UseBrotli": true
    },
    "Session": null,
    "TimeZone": {
      "DefaultTimeZone": "UTC"
    },
    "Localization": {
      "DefaultCulture": "en-US",
      "SupportedCultures": [
      ]
    },
    "Documentation": {
      "Name": "Svc.Places",
      "Description": null,
      "TermsOfServiceUrl": null,
      "Contact": null,
      "License": null,
      "HideDefaultVersion": true
    },
    "HealthCheck": {
    },
    "Metrics": {
    },
    "VirusScan": null,
    "ErrorHandlong": {
      "ExposeErrors": false
    },
    "Authentication": {
      "Jwt": {
        "PublicKey": null
      }
    },
    "Apis": []
  },
  "Logging": {
    "LogLevel": "Information",
    "LogLevelOverrides": [
      {
        "Namespace": "Microsoft",
        "LogLevel": "Warning"
      }
    ]
  },
  "Data": {
    "BatchSize": 25,
    "BulkBatchSize": 500,
    "BulkBatchDelay": 1000,
    "QueryRetryCount": 0,
    "UseLazyLoading": false,
    "StartupAction": "None",
    "UseSensitiveDataLogging": false,
    "QuerySplittingBehavior": "SingleQuery",
    "DefaultCollation": null,
    "ConnectionString": null,
    "Repository": {
      "UseAutoSave": true,
      "QueryIncludeDepth": 4
    },
    "Identity": {
      "TokensExpiration": "24:00:00",
      "UseAudit": "All",
      "User": {
        "IsUniqueEmailAddressRequired": true,
        "IsUniquePhoneNumberRequired": false,
        "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._@+",
        "DefaultRoles": [
          "administrator"
        ]
      },
      "SignIn": {
        "RequireConfirmedEmail": false,
        "RequireConfirmedPhoneNumber": false
      },
      "Lockout": {
        "AllowedForNewUsers": true,
        "MaxFailedAccessAttempts": 3,
        "DefaultLockoutTimeSpan": "00:30:00"
      },
      "Password": {
        "RequireDigit": true,
        "RequireNonAlphanumeric": true,
        "RequireLowercase": true,
        "RequirUppercase": true,
        "RequiredLength": 12,
        "RequiredUniqueCharacters": 3
      }
    },
    "ConnectionPool": null,
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  },
  "Eventing": {
    "Host": "rabbitmq",
    "VHost": "/",
    "Port": 5672,
    "UseSsl": false,
    "Timeout": "00:00:30",
    "Heartbeat": 60,
    "PrefetchCount": 50,
    "Credentials": {
      "Id": null,
      "Secret": null
    },
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  },
  "Storage": {
    "ShareName": "svc-places",
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  }
}